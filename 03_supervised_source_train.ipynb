   "source": [
    "# ============================================================\n",
    "# SESSION-LEVEL SPLIT (avoid window leakage)\n",
    "# ============================================================\n",
    "def get_session_name(npz_obj, idx):\n",
    "    if \"raw_folder_name\" in npz_obj.files:\n",
    "        return str(npz_obj[\"raw_folder_name\"][idx])\n",
    "    if \"pair_id\" in npz_obj.files:\n",
    "        return str(npz_obj[\"pair_id\"][idx]).split(\"_window_\")[0]\n",
    "    return f\"session_{idx}\"\n",
    "\n",
    "def split_train_indices_by_session(npz_obj, val_ratio=0.2, seed=42):\n",
    "    idx_all = np.arange(len(npz_obj[\"label_id\"]))\n",
    "    session_names = np.array([get_session_name(npz_obj, i) for i in idx_all])\n",
    "\n",
    "    unique_sessions = np.unique(session_names)\n",
    "    rng = np.random.default_rng(seed)\n",
    "    rng.shuffle(unique_sessions)\n",
    "\n",
    "    n_val = max(1, int(round(len(unique_sessions) * val_ratio)))\n",
    "    val_sessions = set(unique_sessions[:n_val])\n",
    "\n",
    "    train_idx = [i for i in idx_all if session_names[i] not in val_sessions]\n",
    "    val_idx   = [i for i in idx_all if session_names[i] in val_sessions]\n",
    "\n",
    "    return np.array(train_idx, dtype=np.int64), np.array(val_idx, dtype=np.int64)\n",
    "\n",
    "if USE_PRED_SUPPORT_AS_VAL and pred_support_obj is not None:\n",
    "    train_idx = np.arange(len(train_obj[\"label_id\"]))\n",
    "    val_source = \"pred_support\"\n",
    "else:\n",
    "    train_idx, val_idx = split_train_indices_by_session(train_obj, val_ratio=VAL_RATIO, seed=SEED)\n",
    "    val_source = \"session_split\"\n",
    "\n",
    "print(\"val_source:\", val_source)\n",
    "print(\"train_idx:\", len(train_idx))\n",
    "if val_source == \"session_split\":\n",
    "    print(\"val_idx:\", len(val_idx))"
