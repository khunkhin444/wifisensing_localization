    "def build_hybrid_model(amp_input_shape, pha_input_shape, amp_encoder, num_classes, class_center_map):\n",
    "    amp_in = keras.Input(shape=amp_input_shape, name=\"amp_in\")\n",
    "    pha_in = keras.Input(shape=pha_input_shape, name=\"pha_in\")\n",
    "\n",
    "    # amplitude branch\n",
    "    amp_feat = amp_encoder(amp_in)\n",
    "    amp_feat = layers.Dense(128, activation=\"relu\", name=\"amp_feat\")(amp_feat)\n",
    "\n",
    "    # phase branch\n",
    "    pha_encoder = build_phase_geometry_encoder(pha_input_shape)\n",
    "    pha_feat = pha_encoder(pha_in)\n",
    "\n",
    "    # presence\n",
    "    presence_out = layers.Dense(1, activation=\"sigmoid\", name=\"presence_out\")(amp_feat)\n",
    "\n",
    "    # fused feature\n",
    "    fused = layers.Concatenate()([amp_feat, pha_feat])\n",
    "    fused = layers.Dense(128, activation=\"relu\")(fused)\n",
    "\n",
    "    # class prediction\n",
    "    class_out = layers.Dense(num_classes, activation=\"softmax\", name=\"class_out\")(fused)\n",
    "\n",
    "    # fixed anchor-center lookup matrix\n",
    "    center_matrix = np.zeros((num_classes, 2), dtype=np.float32)\n",
    "    for class_id in range(num_classes):\n",
    "        label_name = inv_label_map[class_id]\n",
    "        center_matrix[class_id] = np.asarray(class_center_map[label_name], dtype=np.float32)\n",
    "\n",
    "    # coarse xy from class probabilities, WITHOUT Lambda\n",
    "    coarse_xy_layer = layers.Dense(\n",
    "        2,\n",
    "        use_bias=False,\n",
    "        trainable=False,\n",
    "        name=\"aoa_xy_out\"\n",
    "    )\n",
    "    coarse_xy = coarse_xy_layer(class_out)\n",
    "\n",
    "    # small residual correction from amplitude\n",
    "    corr = layers.Dense(64, activation=\"relu\")(amp_feat)\n",
    "    raw_delta = layers.Dense(2, activation=\"tanh\")(corr)\n",
    "    amp_delta_out = layers.Rescaling(scale=0.75, name=\"amp_delta_out\")(raw_delta)\n",
    "\n",
    "    # gate correction by presence\n",
    "    gate = layers.Dense(32, activation=\"relu\")(layers.Concatenate()([amp_feat, pha_feat, presence_out]))\n",
    "    gate = layers.Dense(1, activation=\"sigmoid\", name=\"delta_gate\")(gate)\n",
    "\n",
    "    scaled_delta = layers.Multiply()([amp_delta_out, gate])\n",
    "\n",
    "    final_xy_out = layers.Add(name=\"final_xy_out\")([coarse_xy, scaled_delta])\n",
    "\n",
    "    model = keras.Model(\n",
    "        inputs={\"amp_in\": amp_in, \"pha_in\": pha_in},\n",
    "        outputs={\n",
    "            \"presence_out\": presence_out,\n",
    "            \"class_out\": class_out,\n",
    "            \"aoa_xy_out\": coarse_xy,\n",
    "            \"amp_delta_out\": amp_delta_out,\n",
    "            \"final_xy_out\": final_xy_out,\n",
    "        },\n",
    "        name=\"hybrid_anchor_prob_model\"\n",
    "    )\n",
    "\n",
    "    # set fixed anchor-center weights\n",
    "    model.get_layer(\"aoa_xy_out\").set_weights([center_matrix])\n",
    "\n",
    "    return model"
   ]
