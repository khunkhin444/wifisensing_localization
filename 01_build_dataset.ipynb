    "    # \"Empty_Pred\": \"Empty\",\n",
    "\n",
    "    \"LeftDown\": \"LeftDown\",\n",
    "    # \"LeftDown_Far\": \"LeftDown\",\n",
    "\n",
    "    \"LeftMid\": \"LeftMid\",\n",
    "\n",
    "    \"LeftUp\": \"LeftUp\",\n",
    "    # \"LeftUp_Near\": \"LeftUp\",\n",
    "    # \"LeftUp_Pred\": \"LeftUp\",\n",
    "\n",
    "    \"MiddleDown\": \"MiddleDown\",\n",
    "    \"MiddleUp\": \"MiddleUp\",\n",
    "\n",
    "    \"RightDown\": \"RightDown\",\n",
    "    \"RightMid\": \"RightMid\",\n",
    "    \"RightUp\": \"RightUp\",\n",
    "}\n",
    "\n",
    "UNLABELED_PRED_FOLDERS = {\n",
    "    \"Empty_Pred\",\n",
    "    \"LeftDown_Far\",\n",
    "    \"LeftUp_Near\",\n",
    "    \"LeftUp_Pred\",\n",
    "    \"Corner\",\n",
    "    \"Wall\",\n",
    "    \"Center\"\n",
    "}"
