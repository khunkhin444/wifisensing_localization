    "def collect_ssl_paths(*npz_objs): # accepts multiple npz objects and concatenates their paths\n",
    "    rows = []\n",
    "\n",
    "    for obj in npz_objs:\n",
    "        if obj is None:\n",
    "            continue\n",
    "\n",
    "        n = len(obj[\"label_id\"])\n",
    "        for i in range(n):\n",
    "            rows.append({\n",
    "                \"A_amp\": str(obj[\"A_amp_paths\"][i]),\n",
    "                \"B_amp\": str(obj[\"B_amp_paths\"][i]),\n",
    "                \"A_ampavg\": str(obj[\"A_ampavg_paths\"][i]) if \"A_ampavg_paths\" in obj.files else \"\",\n",
    "                \"B_ampavg\": str(obj[\"B_ampavg_paths\"][i]) if \"B_ampavg_paths\" in obj.files else \"\",\n",
    "                \"domain\": str(obj[\"domain\"][i]) if \"domain\" in obj.files else \"unknown\",\n",
    "            })\n",
    "\n",
    "    return rows\n",
    "\n",
    "\n",
    "ssl_rows = collect_ssl_paths(\n",
    "    train_unlab,\n",
    "    pred_support if USE_PRED_SUPPORT_IN_SSL else None,\n",
    "    pred_query if USE_PRED_QUERY_IN_SSL else None,\n",
    ")\n",
    "\n",
    "print(\"Total SSL rows:\", len(ssl_rows))\n",
    "print(\"Example:\", ssl_rows[0])"
   ]
