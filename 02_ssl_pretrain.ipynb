   "source": [
    "def preprocess_amp_sample(row): # load, resize, normalize one sample\n",
    "    x = load_one_amp_pair(row, use_raw_amp=USE_RAW_AMP, use_avecsi=USE_AVECSI)\n",
    "    x = ensure_3d(x)\n",
    "\n",
    "    # resize to target shape\n",
    "    x = tf.image.resize(tf.convert_to_tensor(x, dtype=tf.float32), size=(TARGET_T, TARGET_S)).numpy()\n",
    "\n",
    "    # normalize per-sample\n",
    "    mu = np.mean(x, axis=(0, 1), keepdims=True)\n",
    "    sd = np.std(x, axis=(0, 1), keepdims=True) + 1e-6\n",
    "    x = (x - mu) / sd\n",
    "\n",
    "    return x.astype(np.float32)\n",
    "\n",
    "def random_time_mask(x, ratio=0.08): # mask random contiguous time steps\n",
    "    T = x.shape[0]\n",
    "    n = max(1, int(T * ratio))\n",
    "    start = np.random.randint(0, max(1, T - n + 1))\n",
    "    x = x.copy()\n",
    "    x[start:start+n, :, :] = 0\n",
    "    return x\n",
    "\n",
    "def random_subcarrier_mask(x, ratio=0.08): # mask random contiguous subcarriers\n",
    "    S = x.shape[1]\n",
    "    n = max(1, int(S * ratio))\n",
    "    start = np.random.randint(0, max(1, S - n + 1))\n",
    "    x = x.copy()\n",
    "    x[:, start:start+n, :] = 0\n",
    "    return x\n",
    "\n",
    "def random_scale(x, smin=0.90, smax=1.10): # scale entire sample by random factor\n",
    "    scale = np.random.uniform(smin, smax)\n",
    "    return x * scale\n",
    "\n",
    "def random_jitter(x, std=0.01): # add Gaussian noise to entire sample\n",
    "    return x + np.random.normal(0, std, size=x.shape).astype(np.float32)\n",
    "\n",
    "def augment_amp_view(x): # apply all augmentations to create one augmented view\n",
    "    y = x.copy()\n",
    "\n",
    "    if AUG_USE_GAUSSIAN_NOISE:\n",
    "        y = random_jitter(y, std=AUG_JITTER_STD)\n",
    "\n",
    "    y = random_scale(y, AUG_SCALE_MIN, AUG_SCALE_MAX)\n",
    "    y = random_time_mask(y, AUG_TIME_MASK_RATIO)\n",
    "    y = random_subcarrier_mask(y, AUG_SUB_MASK_RATIO)\n",
    "\n",
    "    return y.astype(np.float32)"
   ]
  },
