   "source": [
    "sample_batch, _ = ssl_gen[0]\n",
    "input_shape = sample_batch[0].shape[1:]   # [T, S, C]\n",
    "\n",
    "encoder = build_amp_encoder(input_shape, embed_dim=EMBED_DIM)\n",
    "projector = build_projector(embed_dim=EMBED_DIM, proj_dim=PROJ_DIM)\n",
    "\n",
    "encoder.summary()\n",
    "projector.summary()\n",
    "\n",
    "trainer = SimCLRTrainer(\n",
    "    encoder=encoder,\n",
    "    projector=projector,\n",
    "    temperature=TEMPERATURE,\n",
    ")\n",
    "\n",
    "optimizer = keras.optimizers.Adam(learning_rate=LR)\n",
    "trainer.compile(optimizer=optimizer)\n",
    "\n",
    "# callbacks = [\n",
    "#     keras.callbacks.CSVLogger(str(OUT_DIR / \"amp_ssl_log.csv\")),\n",
    "# ]\n",
    "\n",
    "callbacks = [\n",
    "    keras.callbacks.CSVLogger(str(OUT_DIR / \"amp_ssl_log.csv\")),\n",
    "    SaveBestEncoderCallback(\n",
    "        encoder=encoder,\n",
    "        projector=projector,\n",
    "        out_dir=OUT_DIR,\n",
    "        monitor=\"loss\",\n",
    "        mode=\"min\",\n",
    "    ),\n",
    "]\n",
    "\n",
    "history = trainer.fit(\n",
    "    ssl_gen,\n",
    "    epochs=EPOCHS,\n",
    "    callbacks=callbacks,\n",
    "    verbose=1,\n",
    ")"
