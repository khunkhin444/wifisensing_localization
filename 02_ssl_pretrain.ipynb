    "def np_load_float32(path):\n",
    "    x = np.load(path)\n",
    "    return x.astype(np.float32)\n",
    "\n",
    "def resize_time_axis(x, target_t):\n",
    "    \"\"\"\n",
    "    x: [T, S, C]\n",
    "    resize along T only using tf.image.resize\n",
    "    \"\"\"\n",
    "    x_tf = tf.convert_to_tensor(x, dtype=tf.float32)\n",
    "    x_tf = tf.image.resize(x_tf, size=(target_t, x.shape[1]), method=\"bilinear\")\n",
    "    return x_tf.numpy()\n",
    "\n",
    "def ensure_3d(x):\n",
    "    \"\"\"\n",
    "    input:\n",
    "      [T, S]      -> [T, S, 1]\n",
    "      [T, S, A]   -> unchanged\n",
    "      [1, S, A]   -> unchanged\n",
    "    \"\"\"\n",
    "    x = np.asarray(x, dtype=np.float32)\n",
    "    if x.ndim == 2:\n",
    "        x = x[..., None]\n",
    "    return x\n",
    "\n",
    "def load_one_amp_pair(row, use_raw_amp=True, use_avecsi=True):\n",
    "    \"\"\"\n",
    "    Build one SSL sample from A/B amplitude.\n",
    "    Output shape:\n",
    "        [T, S, C]\n",
    "    where C depends on chosen concatenation.\n",
    "    \"\"\"\n",
    "\n",
    "    feats = []\n",
    "\n",
    "    if use_raw_amp:\n",
    "        A = ensure_3d(np_load_float32(row[\"A_amp\"]))\n",
    "        B = ensure_3d(np_load_float32(row[\"B_amp\"]))\n",
    "\n",
    "        feats.append(A)\n",
    "        feats.append(B)\n",
    "\n",
    "    if use_avecsi:\n",
    "        if row[\"A_ampavg\"] and row[\"B_ampavg\"]:\n",
    "            Aavg = ensure_3d(np_load_float32(row[\"A_ampavg\"]))\n",
    "            Bavg = ensure_3d(np_load_float32(row[\"B_ampavg\"]))\n",
    "\n",
    "            # if avg is [1, S, A], tile to same T as raw\n",
    "            if use_raw_amp:\n",
    "                Tref = feats[0].shape[0]\n",
    "            else:\n",
    "                Tref = TARGET_T if TARGET_T is not None else Aavg.shape[0]\n",
    "\n",
    "            if Aavg.shape[0] == 1 and Tref > 1:\n",
    "                Aavg = np.repeat(Aavg, Tref, axis=0)\n",
    "            if Bavg.shape[0] == 1 and Tref > 1:\n",
    "                Bavg = np.repeat(Bavg, Tref, axis=0)\n",
    "\n",
    "            feats.append(Aavg)\n",
    "            feats.append(Bavg)\n",
    "\n",
    "    assert len(feats) > 0, \"No amplitude feature selected.\"\n",
    "\n",
    "    # align T/S before concat\n",
    "    T0 = feats[0].shape[0]\n",
    "    S0 = feats[0].shape[1]\n",
    "\n",
    "    aligned = []\n",
    "    for x in feats:\n",
    "        if x.shape[0] != T0 or x.shape[1] != S0:\n",
    "            x = tf.image.resize(tf.convert_to_tensor(x, dtype=tf.float32), size=(T0, S0)).numpy()\n",
    "        aligned.append(x.astype(np.float32))\n",
    "\n",
    "    x = np.concatenate(aligned, axis=-1)  # [T, S, C]\n",
    "    return x"
   ]
