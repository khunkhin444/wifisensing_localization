    "class SSLAmpSequence(keras.utils.Sequence):\n",
    "    def __init__(self, rows, batch_size=32, shuffle=True):\n",
    "        self.rows = rows\n",
    "        self.batch_size = batch_size\n",
    "        self.shuffle = shuffle\n",
    "        self.indices = np.arange(len(rows))\n",
    "        self.on_epoch_end()\n",
    "\n",
    "    def __len__(self):\n",
    "        return math.ceil(len(self.rows) / self.batch_size)\n",
    "\n",
    "    def on_epoch_end(self):\n",
    "        if self.shuffle:\n",
    "            np.random.shuffle(self.indices)\n",
    "\n",
    "    def __getitem__(self, idx):\n",
    "        inds = self.indices[idx * self.batch_size : (idx + 1) * self.batch_size]\n",
    "\n",
    "        v1_list = []\n",
    "        v2_list = []\n",
    "\n",
    "        for i in inds:\n",
    "            x = preprocess_amp_sample(self.rows[i])\n",
    "            v1 = augment_amp_view(x)\n",
    "            v2 = augment_amp_view(x)\n",
    "\n",
    "            v1_list.append(v1)\n",
    "            v2_list.append(v2)\n",
    "\n",
    "        v1 = np.stack(v1_list, axis=0).astype(np.float32)\n",
    "        v2 = np.stack(v2_list, axis=0).astype(np.float32)\n",
    "\n",
    "        # dummy labels not used\n",
    "        y = np.zeros((len(inds),), dtype=np.float32)\n",
    "        return (v1, v2), y"
   ]
  },
