    "def extract_embeddings(npz_obj, encoder, max_n=128):\n",
    "    n = min(len(npz_obj[\"label_id\"]), max_n)\n",
    "    feats = []\n",
    "    labels = []\n",
    "\n",
    "    for i in range(n):\n",
    "        row = {\n",
    "            \"A_amp\": str(npz_obj[\"A_amp_paths\"][i]),\n",
    "            \"B_amp\": str(npz_obj[\"B_amp_paths\"][i]),\n",
    "            \"A_ampavg\": str(npz_obj[\"A_ampavg_paths\"][i]) if \"A_ampavg_paths\" in npz_obj.files else \"\",\n",
    "            \"B_ampavg\": str(npz_obj[\"B_ampavg_paths\"][i]) if \"B_ampavg_paths\" in npz_obj.files else \"\",\n",
    "        }\n",
    "        x = preprocess_amp_sample(row)\n",
    "        x = np.expand_dims(x, axis=0)\n",
    "        emb = encoder.predict(x, verbose=0)[0]\n",
    "\n",
    "        feats.append(emb)\n",
    "        labels.append(int(npz_obj[\"label_id\"][i]))\n",
    "\n",
    "    return np.asarray(feats, dtype=np.float32), np.asarray(labels, dtype=np.int64)"
   ]
  },
